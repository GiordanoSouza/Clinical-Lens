# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
.pnpm-store
.mastra
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Mastra local SQLite storage (Keep ignored even if moving to Convex)
mastra.db*
clinical-lens.db*

# npm lockfile (project uses pnpm)
package-lock.json

# env files (can opt-in for committing if needed)
.env*
!.env.example

# local data dumps
data/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Convex generated files
convex/_generated/

# Tool-specific directories
.windsurf/
.agent/
.agents/
.kilocode/
.claude/
